datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatusType {
  pending
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatusType {
  pending
  completed
  failed
  refunded
}

enum AddressTypeType {
  shipping
  billing
}

enum ContactStatusType {
  unread
  read
  replied
}

enum InventoryTransactionType {
  inbound
  outbound
  adjustment
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(100)
  email        String        @unique @db.VarChar(150)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  isAdmin      Boolean       @default(false) @map("is_admin")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  profile      Profile?
  addresses    Address[]
  customJuices CustomJuice[]
  orders       Order[]
  quizResults  QuizResult[]
  carts        Cart[]
  reviews      Review[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Profile {
  id                String   @id @db.Uuid
  avatarUrl         String?  @map("avatar_url") @db.VarChar(255)
  phoneNumber       String?  @map("phone_number") @db.VarChar(20)
  billingAddressId  String?  @map("billing_address_id") @db.Uuid
  shippingAddressId String?  @map("shipping_address_id") @db.Uuid
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [id], references: [id], onDelete: Cascade)
  billingAddress    Address? @relation("BillingProfile", fields: [billingAddressId], references: [id], onDelete: SetNull)
  shippingAddress   Address? @relation("ShippingProfile", fields: [shippingAddressId], references: [id], onDelete: SetNull)

  @@map("profiles")
}

model Address {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?         @map("user_id") @db.Uuid
  street           String          @db.VarChar(255)
  city             String          @db.VarChar(100)
  state            String          @db.VarChar(100)
  postalCode       String          @map("postal_code") @db.VarChar(20)
  country          String          @db.VarChar(100)
  addressType      AddressTypeType @map("address_type")
  isDefault        Boolean         @default(false) @map("is_default")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingProfiles  Profile[]       @relation("BillingProfile")
  shippingProfiles Profile[]       @relation("ShippingProfile")
  shippingOrders   Order[]         @relation("ShippingOrders")
  billingOrders    Order[]         @relation("BillingOrders")

  @@map("addresses")
}

model Product {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku         String                 @unique @db.VarChar(50)
  name        String                 @db.VarChar(150)
  description String?                @db.Text
  price       Decimal                @db.Decimal(10, 2)
  imageUrl    String?                @map("image_url") @db.VarChar(255)
  category    String?                @db.VarChar(100)
  isActive    Boolean                @default(true) @map("is_active")
  flavor      String?                @db.VarChar(100)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  inventory   Inventory?
  inventoryTx InventoryTransaction[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  images      ProductImage[]

  @@map("products")
}

model ProductImage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String?  @map("product_id") @db.Uuid
  url          String   @db.VarChar(255)
  displayOrder Int      @default(0) @map("display_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product      Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Inventory {
  productId         String   @id @map("product_id") @db.Uuid
  stockQuantity     Int      @default(0) @map("stock_quantity")
  lowStockThreshold Int?     @default(10) @map("low_stock_threshold")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model InventoryTransaction {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String?                  @map("product_id") @db.Uuid
  transactionType InventoryTransactionType @map("transaction_type")
  quantity        Int
  referenceId     String?                  @map("reference_id") @db.VarChar(100)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  product         Product?                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

model CustomJuice {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  blendName   String      @map("blend_name") @db.VarChar(100)
  ingredients Json
  colorRgb    String      @map("color_rgb") @db.VarChar(50)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders      Order[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("custom_juices")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId        String?      @map("cart_id") @db.Uuid
  productId     String?      @map("product_id") @db.Uuid
  customJuiceId String?      @map("custom_juice_id") @db.Uuid
  quantity      Int
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  cart          Cart?        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product       Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  customJuice   CustomJuice? @relation(fields: [customJuiceId], references: [id], onDelete: SetNull)

  @@map("cart_items")
}

model Order {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String?      @map("user_id") @db.Uuid
  name              String       @db.VarChar(100)
  email             String       @db.VarChar(150)
  flavorPreference  String       @map("flavor_preference") @db.VarChar(100)
  customJuiceId     String?      @map("custom_juice_id") @db.Uuid
  status            String?      @default("pending") @db.VarChar(50)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  subtotal          Decimal      @default(0.00) @db.Decimal(10, 2)
  tax               Decimal      @default(0.00) @db.Decimal(10, 2)
  shipping          Decimal      @default(0.00) @db.Decimal(10, 2)
  totalAmount       Decimal      @default(0.00) @map("total_amount") @db.Decimal(10, 2)
  shippingAddressId String?      @map("shipping_address_id") @db.Uuid
  billingAddressId  String?      @map("billing_address_id") @db.Uuid
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  customJuice       CustomJuice? @relation(fields: [customJuiceId], references: [id], onDelete: SetNull)
  shippingAddress   Address?     @relation("ShippingOrders", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress    Address?     @relation("BillingOrders", fields: [billingAddressId], references: [id], onDelete: SetNull)
  payments          Payment[]
  items             OrderItem[]

  @@map("orders")
}

model OrderItem {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String?      @map("order_id") @db.Uuid
  productId       String?      @map("product_id") @db.Uuid
  customJuiceId   String?      @map("custom_juice_id") @db.Uuid
  quantity        Int
  priceAtPurchase Decimal      @map("price_at_purchase") @db.Decimal(10, 2)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  order           Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  customJuice     CustomJuice? @relation(fields: [customJuiceId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Payment {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId               String?  @map("order_id") @db.Uuid
  providerTransactionId String   @unique @map("provider_transaction_id") @db.VarChar(150)
  amount                Decimal  @db.Decimal(10, 2)
  currency              String?  @default("usd") @db.VarChar(10)
  status                String   @db.VarChar(50)
  provider              String?  @default("stripe") @db.VarChar(50)
  webhookPayload        Json?    @map("webhook_payload")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  order                 Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("payments")
}

model EmailLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipient    String   @db.VarChar(150)
  subject      String   @db.VarChar(255)
  status       String   @db.VarChar(50)
  errorMessage String?  @map("error_message") @db.Text
  sentAt       DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  @@map("email_logs")
}

model NewsletterSubscriber {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(150)
  isActive     Boolean  @default(true) @map("is_active")
  subscribedAt DateTime @default(now()) @map("subscribed_at") @db.Timestamptz(6)

  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String            @db.VarChar(100)
  email     String            @db.VarChar(150)
  subject   String            @db.VarChar(200)
  message   String            @db.Text
  status    ContactStatusType @default(unread)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("contact_messages")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  productId String?  @map("product_id") @db.Uuid
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("reviews")
}

model QuizResult {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String?  @map("user_id") @db.Uuid
  primaryRecommendation String   @map("primary_recommendation") @db.VarChar(100)
  quizAnswers           Json     @map("quiz_answers")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("quiz_results")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String   @db.VarChar(100)
  entityAffected String   @map("entity_affected") @db.VarChar(100)
  details        Json?
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
